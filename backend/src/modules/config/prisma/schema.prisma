// Prisma schema for config module
// Centralized configuration and templates

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma-client/config"
}

datasource db {
  provider = "postgresql"
}

model PromptTemplate {
  id          String      @id @default(cuid())
  name        String
  platform    Platform
  contentType ContentType
  template    String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([isActive])
  @@index([platform])
  @@index([contentType])
  @@map("prompt_templates")
}

// Phase 1: single row, key is always "cj_all".
// Phase 2 multi-network / multi-tenant will need composite key (network + userId) — see TODOS.md [DISCO-6]
model DiscoveryCache {
  id        String   @id @default(cuid())
  key       String   @unique
  data      Json     // DiscoverProduct[]
  meta      Json?    // { partial?: boolean, failedAdvertisers?: { name: string, error: string }[] }
  updatedAt DateTime @updatedAt

  @@map("discovery_cache")
}

model PublishProvider {
  id               String   @id @default(cuid())
  key              String   // 'BUFFER' | 'PUBLER' | 'DIRECT'
  label            String   // display name
  enabledPlatforms Json     // string[] — platforms this provider handles
  credentials      Json     // { apiToken?, organizationId?, wordpressUrl?, etc. }
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([key])
  @@index([isActive])
  @@map("publish_providers")
}

enum Platform {
  WORDPRESS
  SHOPIFY
  FACEBOOK
  INSTAGRAM
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  PINTEREST
  MASTODON
  THREADS
}

enum ContentType {
  BLOG_POST
  SOCIAL_POST
  VIDEO_SCRIPT
  CAROUSEL
  THREAD
  HERO_COPY
}
