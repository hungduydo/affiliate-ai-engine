// Prisma schema for distribution-hub module
// Tracks publishing logs and status of content distribution

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma-client/distribution-hub"
}

datasource db {
  provider = "postgresql"
}

model PublishLog {
  id            String        @id @default(cuid())
  contentId     String // NO FOREIGN KEY — stored as reference only
  platform      Platform
  provider      String?       // provider key: 'BUFFER' | 'PUBLER' | 'DIRECT' — null for legacy rows
  providerId    String?       // PublishProvider.id — used to load credentials at publish time; null for legacy rows
  publishedLink String?
  status        PublishStatus @default(PENDING)
  errorMessage  String?
  publishedAt   DateTime?
  scheduledAt   DateTime?     // null = publish now; BullMQ delay owns scheduling
  assets        Json?         // PublishAsset[]
  bufferMode    String?       // legacy — kept for existing rows
  bufferDueAt   DateTime?     // legacy — kept for existing rows
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([contentId])
  @@index([status])
  @@index([platform])
  @@map("publish_logs")
}

enum Platform {
  WORDPRESS
  SHOPIFY
  FACEBOOK
  INSTAGRAM
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  PINTEREST
  MASTODON
  THREADS
  // Deprecated — retained for existing rows; not used for new publish logs
  BUFFER_TWITTER
  BUFFER_INSTAGRAM
  BUFFER_LINKEDIN
  BUFFER_TIKTOK
  BUFFER_PINTEREST
  BUFFER_FACEBOOK
  BUFFER_YOUTUBE
  BUFFER_MASTODON
  BUFFER_THREADS
}

enum PublishStatus {
  PENDING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}
