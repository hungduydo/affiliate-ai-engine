// Prisma schema for distribution-hub module
// Tracks publishing logs and status of content distribution

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma-client/distribution-hub"
}

datasource db {
  provider = "postgresql"
}

model PublishLog {
  id            String        @id @default(cuid())
  contentId     String // NO FOREIGN KEY — stored as reference only
  platform      Platform
  publishedLink String?
  status        PublishStatus @default(PENDING)
  errorMessage  String?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([contentId])
  @@index([status])
  @@index([platform])
  @@map("publish_logs")
}

enum Platform {
  WORDPRESS
  FACEBOOK
  TIKTOK
  YOUTUBE
  SHOPIFY
  BUFFER_TWITTER
  BUFFER_INSTAGRAM
  BUFFER_LINKEDIN
  BUFFER_TIKTOK
  BUFFER_PINTEREST
  BUFFER_FACEBOOK
  BUFFER_YOUTUBE
  BUFFER_MASTODON
  BUFFER_THREADS
}

enum PublishStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
}
