// This is your Prisma schema file for product-management module.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/@prisma-client/product-management"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String        @id @default(cuid())
  externalId    String        @unique
  source        String        // "shopee" | "clickbank" | "cj" | "lazada"
  name          String
  description   String?
  price         Float?
  commission    Float?        // Commission %
  affiliateLink String        @unique
  productLink   String?       // Direct product URL (for enrichment crawl)
  imageUrl      String?
  rawData       Json          // Original API response blob
  status        ProductStatus @default(ACTIVE)
  enrichStatus  EnrichStatus  @default(PENDING)
  enrichedAt    DateTime?
  metadata      Json?         // tags, categories, gallery, videos, rating, etc.
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([source])
  @@index([status])
  @@index([enrichStatus])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum EnrichStatus {
  PENDING
  ENRICHING
  DONE
  FAILED
  SKIPPED
}
