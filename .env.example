# ============================================
# OmniAffiliate AI Engine — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# --- Databases (Isolated Per-Module) ---
DATABASE_URL_PRODUCTS="postgresql://postgres:postgres_dev@localhost:5432/products_db"
DATABASE_URL_CONTENT="postgresql://postgres:postgres_dev@localhost:5432/content_db"
DATABASE_URL_PUBLISH="postgresql://postgres:postgres_dev@localhost:5432/publish_db"
DATABASE_URL_CONFIG="postgresql://postgres:postgres_dev@localhost:5432/config_db"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Backend ---
BACKEND_PORT=3000
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_secret_32_chars_min

# --- AI (Phase 2) ---
GOOGLE_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# --- Source Connectors (Phase 2) ---
# ClickBank
CLICKBANK_DEV_API_KEY=your_clickbank_dev_api_key
CLICKBANK_CLERK_ID=your_clickbank_affiliate_id

# CJ Affiliate
CJ_WEBSITE_ID=your_cj_website_id
CJ_API_TOKEN=your_cj_personal_access_token

# Shopee Affiliate (Playwright scraper — save cookies from browser DevTools)
SHOPEE_COOKIE_FILE_PATH=./shopee-cookies.json

# Backend internal URL (for service-to-service calls)
BACKEND_INTERNAL_URL=http://localhost:3000

# --- Distribution (Phase 3) ---
WORDPRESS_URL=https://your-site.com
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# Shopify (Phase 4)
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_BLOG_ID=
